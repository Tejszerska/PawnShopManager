<local:OneViewBase x:Class="MVVMFirma.Views.NewPurchaseContract"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MVVMFirma.Views"
             mc:Ignorable="d" 
             d:DesignHeight="550" d:DesignWidth="800">

    <Grid>
        <TabControl Margin="5">

            <TabItem Header="1. Items">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" Content="+ Create New Item" 
                            Command="{Binding AddItemCommand}" 
                            Height="30" Width="150" HorizontalAlignment="Left" Margin="0,0,0,10"/>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding PurchaseContractItemsList}" AutoGenerateColumns="False" IsReadOnly="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding ItemId}" IsReadOnly="True" Width="50"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding ItemName}" IsReadOnly="True" Width="*"/>
                            <DataGridTextColumn Header="Purchase Price" Binding="{Binding PurchasePrice, StringFormat=C, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
                            <DataGridTextColumn Header="Notes" Binding="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" Width="200"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <TextBlock Text="Total Purchase Price: " FontSize="16" FontWeight="Bold"/>
                        <TextBlock Text="{Binding Total_Purchase_Price, StringFormat=C}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource MainText}"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="2. Contract Details">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="Client ID" VerticalAlignment="Center"/>
                    <Grid Grid.Row="0" Grid.Column="1" Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0" Text="{Binding Client_Id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                 VerticalContentAlignment="Center" IsReadOnly="True"/>

                        <Button Grid.Column="1" Content="..." Command="{Binding ShowClientsCommand}" Margin="5,0,0,0"/>

                        <Button Grid.Column="2" Content="+" Command="{Binding AddClientsCommand}" Margin="5,0,0,0"/>
                    </Grid>

                    <Label Grid.Row="1" Grid.Column="0" Content="Client Name" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Margin="0,5" IsEnabled="False" 
                             Text="{Binding ClientName_Preview}"/>

                    <Label Grid.Row="2" Grid.Column="0" Content="Document No" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Margin="0,5" IsEnabled="False" 
                             Text="{Binding ClientDoc_Preview}"/>

                    <Label Grid.Row="3" Grid.Column="0" Content="Agreement No." VerticalAlignment="Center"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Margin="0,5" 
                             Text="{Binding Agreement_Number}" VerticalContentAlignment="Center"/>

                    <Label Grid.Row="4" Grid.Column="0" Content="Purchase Date" VerticalAlignment="Center"/>
                    <DatePicker Grid.Row="4" Grid.Column="1" Margin="0,5" 
                                SelectedDate="{Binding Purchase_Date}" VerticalContentAlignment="Center"/>

                    <Label Grid.Row="5" Grid.Column="0" Content="Total Price" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="5" Grid.Column="1" Margin="0,5" IsEnabled="False" 
                             Text="{Binding Total_Purchase_Price, StringFormat=C}" VerticalContentAlignment="Center"/>

                    <Label Grid.Row="6" Grid.Column="0" Content="Status" VerticalAlignment="Center"/>
                    <ComboBox Grid.Row="6" Grid.Column="1" Margin="0,5"
                              ItemsSource="{Binding ContractStatusesItems}"
                              DisplayMemberPath="name"
                              SelectedValuePath="contract_status_id"
                              SelectedValue="{Binding Status_Id, Mode=TwoWay}" 
                              VerticalContentAlignment="Center"/>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</local:OneViewBase>