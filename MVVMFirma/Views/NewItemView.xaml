<local:OneViewBase x:Class="MVVMFirma.Views.NewItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MVVMFirma.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid>
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="150"/>
        <ColumnDefinition Width="200"/>
    </Grid.ColumnDefinitions>

    <Grid.RowDefinitions>
        <RowDefinition Height="40"/>
        <RowDefinition Height="40"/>
        <RowDefinition Height="40"/>
        <RowDefinition Height="40"/>
        <RowDefinition Height="40"/>
        <RowDefinition Height="40"/>
        <RowDefinition Height="40"/>
        <RowDefinition Height="40"/>
        <RowDefinition Height="40"/>
        <RowDefinition Height="40"/>
    </Grid.RowDefinitions>

    <Label Grid.Column="0" Grid.Row="0" Content="Name" Margin="0,8,0,8"/>
        <TextBox Grid.Column="1" Grid.Row="0" Margin="0,8,0,8" Text="{Binding Path=Name, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay, ValidatesOnDataErrors=True}"/>

    <Label Grid.Column="0" Grid.Row="1" Content="Category" Margin="0,8,0,8"/>
        <ComboBox Grid.Row="1" Grid.Column="1" Height="28" 
  ItemsSource="{Binding CategoriesItems}"
  DisplayMemberPath="name"
  SelectedValuePath="category_id"
  SelectedValue="{Binding Category_Id, Mode=TwoWay}"
  VerticalContentAlignment="Center"/>

    <Label Grid.Column="0" Grid.Row="2" Content="Description" Margin="0,8,0,8"/>
    <TextBox Grid.Column="1" Grid.Row="2" Margin="0,8,0,8" Text="{Binding Path=Description, UpdateSourceTrigger=PropertyChanged}"/>

    <Label Grid.Column="0" Grid.Row="3" Content="Estimated value" Margin="0,8,0,8"/>
        <TextBox Grid.Column="1" Grid.Row="3" Margin="0,8,0,8" Text="{Binding Path=Estimated_Value, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay, ValidatesOnDataErrors=True}"/>

    <Label Grid.Column="0" Grid.Row="4" Content="Sale price" Margin="0,8,0,8"/>
        <TextBox Grid.Column="1" Grid.Row="4" Margin="0,8,0,8" Text="{Binding Path=Sale_Price, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay, ValidatesOnDataErrors=True}"/>

    <Label Grid.Column="0" Grid.Row="5" Content="Condition" Margin="0,8,0,8"/>
        <ComboBox Grid.Row="5" Grid.Column="1"  Height="28"
  ItemsSource="{Binding ItemConditionsItems}"
  DisplayMemberPath="name"
  SelectedValuePath="condition_id"
  SelectedValue="{Binding Condition_Id, Mode=TwoWay}"
  VerticalContentAlignment="Center"/>

    <Label Grid.Column="0" Grid.Row="7" Content="Acq. source type" Margin="0,8,0,8"/>
        <ComboBox Grid.Row="7" Grid.Column="1"  Height="28"
          ItemsSource="{Binding AcquisitionSourceTypesItems}"
          DisplayMemberPath="name"
          SelectedValuePath="acquisition_source_type_id" 
          SelectedValue="{Binding Acquisition_Source_Type_Id, Mode=TwoWay}"
          VerticalContentAlignment="Center"/>

        <Label Grid.Column="0" Grid.Row="6" Content="Acq. source ID" Margin="0,8,0,8"/>
    <TextBox Grid.Column="1" Grid.Row="6" Margin="0,8,0,8" Text="{Binding Path=Acquisition_Source_Id, UpdateSourceTrigger=PropertyChanged}"/>

    <Label Grid.Column="0" Grid.Row="8" Content="Current branch ID" Margin="0,8,0,8"/>
        <ComboBox Grid.Column="1" Grid.Row="8" Margin="0,8,0,8" Height="28"
          VerticalContentAlignment="Center"
          ItemsSource="{Binding BranchesItems}"
          DisplayMemberPath="name"
          SelectedValuePath="branch_id"
          SelectedValue="{Binding Current_Branch_Id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

        <Label Grid.Column="0" Grid.Row="9" Content="Item status" Margin="0,8,0,8"/>
        <ComboBox Grid.Row="9" Grid.Column="1"  Height="28"
  ItemsSource="{Binding ItemStatusesItems}"
  DisplayMemberPath="name"
  SelectedValuePath="item_status_id"
  SelectedValue="{Binding Item_Status_Id, Mode=TwoWay}"
  VerticalContentAlignment="Center"/>
    </Grid>
</local:OneViewBase>
